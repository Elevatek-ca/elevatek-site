<section class="section" id="pricing">
  <div class="wrap">
    <div class="section-head center reveal">
      <p class="eyebrow">Pricing</p>
      <h2>Three ways to start.</h2>
      <p class="lead">A quick answer, on-demand help, or someone who owns the roadmap. Pick your speed.</p>
    </div>
    <div class="price-grid">
      <article class="plan reveal">
        <p class="plan-tag">Get a read first</p>
        <p class="plan-name">$0</p>
        <p class="plan-sub">Free strategy session</p>
        <ul>
          <li>A 30-minute call, no prep needed</li>
          <li>An honest read on your current stack</li>
          <li>What we'd fix first, and in what order</li>
          <li>No deck, no pitch, no obligation</li>
        </ul>
        <a class="btn btn-ghost" href="/contact?type=session">Book the session</a>
      </article>
      <article class="plan featured reveal">
        <p class="plan-tag">On-demand</p>
        <p class="plan-name">Hourly</p>
        <p class="plan-sub">Flexible contract</p>
        <ul>
          <li>Pay as you go</li>
          <li>No SOW required</li>
          <li>Senior consultants only</li>
          <li>Scope as narrow or broad as you need</li>
        </ul>
        <a class="btn btn-light" href="/contact?type=hourly">Start hourly</a>
      </article>
      <article class="plan reveal">
        <p class="plan-tag">Ongoing</p>
        <p class="plan-name">Retainer</p>
        <p class="plan-sub">Managed engagements</p>
        <ul>
          <li>Three-month minimum</li>
          <li>A managed backlog, shipped weekly</li>
          <li>Priority response</li>
          <li>Volume pricing</li>
        </ul>
        <a class="btn btn-ghost" href="/contact?type=retainer">Talk retainer</a>
      </article>
    </div>
    <p class="fineprint">Not sure which fits? That's what the free session is for.</p>
  </div>
</section>
