        <!-- elevation gridlines -->
        <line class="gridline" x1="0" y1="408" x2="640" y2="408"/>
        <line class="gridline" x1="0" y1="344" x2="640" y2="344"/>
        <line class="gridline" x1="0" y1="278" x2="640" y2="278"/>
        <line class="gridline" x1="0" y1="210" x2="640" y2="210"/>
        <line class="gridline" x1="0" y1="140" x2="640" y2="140"/>
        <!-- topographic contours -->
        <path class="contour" d="M0,330 C140,300 260,340 400,250 S600,180 640,150"/>
        <path class="contour" d="M0,250 C160,230 300,260 460,160 S600,110 640,95"/>
        <!-- the ascent -->
        <path class="summit-line" d="M28,408 L110,408 L148,344 L238,344 L276,278 L366,278 L404,210 L494,210 L532,140 L606,140"/>
        <!-- stack nodes -->
        <g class="node"><circle cx="28" cy="408" r="6"/><text x="22" y="432">spreadsheets</text></g>
        <g class="node"><circle cx="148" cy="344" r="6"/><text x="142" y="368">crm</text></g>
        <g class="node"><circle cx="276" cy="278" r="6"/><text x="270" y="302">marketing automation</text></g>
