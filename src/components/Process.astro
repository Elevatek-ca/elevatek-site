<!-- ════════════════════════════════════════════════════
     COMPONENT: Process.astro
     ════════════════════════════════════════════════════ -->
<section class="section process" id="process">
  <div class="wrap on-dark">
    <div class="section-head reveal">
      <p class="eyebrow">How we work</p>
      <h2>Three steps. No mystery.</h2>
      <p class="lead">Step one costs you thirty minutes. Step three ends with your team not needing us.</p>
    </div>
    <div class="steps">
      <article class="step reveal">
        <h3>Assess</h3>
        <p>A free 30-minute session. You walk us through the stack, we tell you what we'd fix first. If we're not the right fit, we say so and point you somewhere better.</p>
        <div class="mini" aria-hidden="true">
          <div class="mini-row"><em>data</em><div class="bar"><i style="--w:46%;--c:var(--warn)"></i></div></div>
          <div class="mini-row"><em>flows</em><div class="bar"><i style="--w:72%;--c:#6E89FF"></i></div></div>
          <div class="mini-row"><em>owners</em><div class="bar"><i style="--w:31%;--c:var(--warn)"></i></div></div>
        </div>
      </article>
      <article class="step reveal">
        <h3>Design</h3>
        <p>A roadmap with priorities, owners, and price tags. You see the whole plan before you commit to any build.</p>
        <div class="mini" aria-hidden="true">
          <div class="mini-row"><em>now</em><div class="bar"><i style="--w:38%;--c:#6E89FF"></i></div></div>
          <div class="mini-row"><em>next</em><div class="bar"><i class="off" style="--x:20%;--w:42%;--c:#4A63D6"></i></div></div>
          <div class="mini-row"><em>later</em><div class="bar"><i class="off" style="--x:46%;--w:48%;--c:#2F3D74"></i></div></div>
        </div>
      </article>
      <article class="step reveal">
        <h3>Build &amp; run</h3>
        <p>We ship in weekly increments, document as we go, and train your team on every piece we hand over.</p>
        <div class="mini-weeks" aria-hidden="true">
          <span class="wk done">w1</span>
          <span class="wk done">w2</span>
          <span class="wk done">w3</span>
          <span class="wk now">w4</span>
        </div>
      </article>
    </div>
  </div>
</section>
