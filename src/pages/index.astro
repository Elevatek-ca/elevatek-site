---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import LogoBand from '../components/LogoBand.astro';
import LeadToCash from '../components/LeadToCash.astro';
import Services from '../components/Services.astro';
import Features from '../components/Features.astro';
import Process from '../components/Process.astro';
import Calculator from '../components/Calculator.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import Closer from '../components/Closer.astro';

// JSON-LD is injected via set:html so its leading HTML comment survives the build
// (Astro strips comments inside named slots otherwise). Canonical + Open Graph now
// come from Base props.
const structuredData = `<!-- Structured data: verified NAP only. Add sameAs (LinkedIn) when ready. -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Elevatek",
  "legalName": "Elevatek Consulting Inc.",
  "url": "https://elevatek.ca/",
  "email": "info@elevatek.ca",
  "telephone": "+1-514-961-8625",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2355 Guenette Street",
    "addressLocality": "Val-David",
    "addressRegion": "QC",
    "postalCode": "J0T 2N0",
    "addressCountry": "CA"
  },
  "knowsLanguage": ["en", "fr"],
  "areaServed": ["North America", "South America", "Europe"],
  "description": "GTM systems consultancy. Salesforce, HubSpot, and Marketing Cloud implementation, integration, and fractional RevOps for B2B teams."
}
</script>`;
---
<Base
  title="GTM systems consultancy — Salesforce & HubSpot | Elevatek"
  description="Elevatek is a Canadian GTM systems consultancy. We design, build, and run Salesforce, HubSpot, and Marketing Cloud so your revenue numbers finally agree."
  canonical="https://elevatek.ca/"
  ogTitle="Elevatek — GTM systems consultancy"
  ogDescription="Salesforce, HubSpot, and Marketing Cloud, wired together so your pipeline numbers stop arguing. Canadian, serving the Americas and Europe."
  home={true}
>
  <Fragment slot="head-end" set:html={structuredData} />

  <Hero />
  <LogoBand />
  <LeadToCash />
  <Services />
  <Features />
  <Process />
  <Calculator />
  <Pricing />
  <Testimonials />
  <Faq />
  <Closer />
</Base>
