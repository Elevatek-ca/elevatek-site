---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — Elevatek"
  description="Tell us what's going on in your stack. Five questions, two minutes, and a human replies with next steps, not a deck."
  ctaHref="#form"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://elevatek.ca/contact">
  </Fragment>

  <!-- ════════════════════════════════════════════════════
       COMPONENT: ContactForm.astro
       Submit: set FORM_ENDPOINT below (Formspree / Netlify
       function / worker). Until then, submit composes a
       mailto with the full summary — works with no backend.
       ════════════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Contact</p>
      <h1>Tell us what's going on in the stack.</h1>
      <p class="lead">Five questions, two minutes. A human replies with next steps, not a deck.</p>
    </div>
  </section>

  <section>
    <div class="wrap contact-grid">
      <form id="form" novalidate>
        <div class="fsection">
          <p class="eyebrow">01 · Who's asking</p>
          <div class="fchips">
            <label class="fchip"><input type="radio" name="role" value="RevOps"><span>RevOps</span></label>
            <label class="fchip"><input type="radio" name="role" value="IT / Systems"><span>IT / Systems</span></label>
            <label class="fchip"><input type="radio" name="role" value="VP Sales or Marketing"><span>VP Sales / Marketing</span></label>
            <label class="fchip"><input type="radio" name="role" value="Salesforce admin"><span>Salesforce admin</span></label>
            <label class="fchip"><input type="radio" name="role" value="Founder / CEO"><span>Founder / CEO</span></label>
            <label class="fchip"><input type="radio" name="role" value="CTO"><span>CTO</span></label>
            <label class="fchip"><input type="radio" name="role" value="Other"><span>Other</span></label>
          </div>
        </div>

        <div class="fsection">
          <p class="eyebrow">02 · Your stack</p>
          <div class="fchips">
            <label class="fchip"><input type="checkbox" name="stack" value="Salesforce"><span>Salesforce</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="HubSpot"><span>HubSpot</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="Marketing Cloud"><span>Marketing Cloud</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="Pardot / MCAE"><span>Pardot / MCAE</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="NetSuite"><span>NetSuite</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="Dynamics"><span>Dynamics</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="Other ERP"><span>Other ERP</span></label>
            <label class="fchip"><input type="checkbox" name="stack" value="Mostly spreadsheets"><span>Mostly spreadsheets</span></label>
          </div>
        </div>

        <div class="fsection">
          <p class="eyebrow">03 · What you're after</p>
          <div class="fchips">
            <label class="fchip"><input type="radio" name="engagement" value="Free strategy session"><span>Free strategy session</span></label>
            <label class="fchip"><input type="radio" name="engagement" value="Hourly help"><span>Hourly help</span></label>
            <label class="fchip"><input type="radio" name="engagement" value="Retainer"><span>Retainer</span></label>
            <label class="fchip"><input type="radio" name="engagement" value="Not sure yet"><span>Not sure yet</span></label>
          </div>
        </div>

        <div class="fsection">
          <p class="eyebrow">04 · How soon</p>
          <div class="fchips">
            <label class="fchip"><input type="radio" name="urgency" value="Yesterday"><span>Yesterday</span></label>
            <label class="fchip"><input type="radio" name="urgency" value="This month"><span>This month</span></label>
            <label class="fchip"><input type="radio" name="urgency" value="This quarter"><span>This quarter</span></label>
            <label class="fchip"><input type="radio" name="urgency" value="Just exploring"><span>Just exploring</span></label>
          </div>
        </div>

        <div class="fsection">
          <p class="eyebrow">05 · The details</p>
          <div class="frow">
            <div class="field">
              <label for="f-name">Your name</label>
              <input type="text" id="f-name" name="name" autocomplete="name" required>
            </div>
            <div class="field">
              <label for="f-company">Company</label>
              <input type="text" id="f-company" name="company" autocomplete="organization">
            </div>
          </div>
          <div class="field">
            <label for="f-email">Work email</label>
            <input type="email" id="f-email" name="email" autocomplete="email" required>
          </div>
          <div class="field">
            <label for="f-msg">What's going on in the stack?</label>
            <textarea id="f-msg" name="message" placeholder="The symptom is fine. We'll find the cause together."></textarea>
          </div>
          <div class="fchips" role="group" aria-label="Preferred language">
            <label class="fchip"><input type="radio" name="lang" value="English"><span>English</span></label>
            <label class="fchip"><input type="radio" name="lang" value="Français"><span>Français</span></label>
            <label class="fchip"><input type="radio" name="lang" value="Either" checked><span>Either / les deux</span></label>
          </div>
        </div>

        <!-- honeypot -->
        <div class="hp" aria-hidden="true">
          <label>Leave this empty<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
        </div>

        <button class="btn btn-primary" type="submit">Send it</button>
        <p class="form-error" id="form-error" role="alert">Name and a valid work email, and we're good.</p>
        <p class="form-note">Goes straight to our inbox. A human reads it.</p>

        <div class="sister book">
          <p class="book-line">Ready to book? <a class="btn btn-primary book-btn" id="calendly-link" href="https://calendly.com/elevatek-consulting/intro-call">Pick a time →</a></p>
          <p>Email <a href="mailto:info@elevatek.ca">info@elevatek.ca</a> or call <a href="tel:+15149618625">+1 (514) 961-8625</a>. Same humans either way.</p>
        </div>
      </form>

      <aside class="req reveal in" aria-label="Your request so far">
        <div class="widget-head">
          <span class="widget-label">Your request</span>
          <span class="badge-you">Live</span>
        </div>
        <div class="req-rows">
          <div class="req-row"><b>Role</b><span id="s-role"></span></div>
          <div class="req-row"><b>Stack</b><span id="s-stack"></span></div>
          <div class="req-row"><b>After</b><span id="s-engagement"></span></div>
          <div class="req-row"><b>When</b><span id="s-urgency"></span></div>
          <div class="req-row"><b>Language</b><span id="s-lang">Either / les deux</span></div>
        </div>
        <p class="wnote">we'll come back with next steps, not a pitch.</p>
      </aside>
    </div>
  </section>

  <Fragment slot="body-end">
    <script is:inline>
// ── form logic ──────────────────────────────────────────
const FORM_ENDPOINT = ''; // TODO: set Formspree/Netlify/worker URL. Empty = mailto compose.

const form = document.getElementById('form');
const err = document.getElementById('form-error');

const read = () => {
  const v = n => (form.querySelector(`input[name="${n}"]:checked`) || {}).value || '';
  return {
    role: v('role'),
    stack: [...form.querySelectorAll('input[name="stack"]:checked')].map(i => i.value).join(', '),
    engagement: v('engagement'),
    urgency: v('urgency'),
    lang: v('lang'),
    name: form.querySelector('input[name="name"]').value.trim(),
    company: form.company.value.trim(),
    email: form.email.value.trim(),
    message: form.message.value.trim()
  };
};

// live summary
const sync = () => {
  const d = read();
  document.getElementById('s-role').textContent = d.role;
  document.getElementById('s-stack').textContent = d.stack;
  document.getElementById('s-engagement').textContent = d.engagement;
  document.getElementById('s-urgency').textContent = d.urgency;
  document.getElementById('s-lang').textContent = d.lang;
};
form.addEventListener('change', sync);

// ?type= preselect from homepage CTAs
const type = new URLSearchParams(location.search).get('type');
const map = { session: 'Free strategy session', hourly: 'Hourly help', retainer: 'Retainer' };
if (map[type]) {
  const input = form.querySelector(`input[name="engagement"][value="${map[type]}"]`);
  if (input) { input.checked = true; sync(); }
}

// submit
form.addEventListener('submit', async e => {
  e.preventDefault();
  if (form.website.value) return; // honeypot
  const d = read();
  const valid = d.name && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(d.email);
  err.classList.toggle('show', !valid);
  if (!valid) return;

  const lines = [
    'Role: ' + (d.role || '-'),
    'Stack: ' + (d.stack || '-'),
    'After: ' + (d.engagement || '-'),
    'When: ' + (d.urgency || '-'),
    'Language: ' + (d.lang || '-'),
    'Company: ' + (d.company || '-'),
    'Name: ' + d.name,
    'Email: ' + d.email,
    '',
    d.message
  ];

  if (FORM_ENDPOINT) {
    try {
      const res = await fetch(FORM_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(d)
      });
      if (!res.ok) throw new Error();
      form.outerHTML = '<div class="sent"><h2>Got it.</h2><p>A human will read this and reply with next steps. Talk soon.</p></div>';
    } catch {
      err.textContent = "That didn't go through. Email us directly: info@elevatek.ca";
      err.classList.add('show');
    }
  } else {
    const subject = 'Elevatek — ' + (d.engagement || 'inquiry') + (d.company ? ' — ' + d.company : '');
    location.href = 'mailto:info@elevatek.ca?subject=' + encodeURIComponent(subject) +
                    '&body=' + encodeURIComponent(lines.join('\n'));
  }
});

// ── Calendly popup ──────────────────────────────────────
// Lazy: no Calendly assets touch the page until the first click. The link's
// href is the real Calendly URL, so it still works with JS disabled.
const calendlyUrl = 'https://calendly.com/elevatek-consulting/intro-call';
const calendlyLink = document.getElementById('calendly-link');
let calendlyReady = false;
if (calendlyLink) {
  calendlyLink.addEventListener('click', e => {
    e.preventDefault();
    const openPopup = () => { if (window.Calendly) Calendly.initPopupWidget({ url: calendlyUrl }); };
    if (calendlyReady) { openPopup(); return; } // assets already injected
    calendlyReady = true;
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://assets.calendly.com/assets/external/widget.css';
    document.head.appendChild(css);
    const js = document.createElement('script');
    js.src = 'https://assets.calendly.com/assets/external/widget.js';
    js.onload = openPopup;
    document.body.appendChild(js);
  });
}
    </script>
  </Fragment>
</Base>

<style>
  /* booking panel — two lines, small-button link */
  .book{display:flex;flex-direction:column;gap:10px}
  .book p{margin:0}
  .book-line{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .book .book-btn{padding:.5em 1.05em;font-size:.9rem}
</style>
