  description="This page is off the map."
  noindex={true}
  minimalFooter={true}
>
  <section class="lost">
    <div>
      <p class="eyebrow">Off the map</p>
      <p class="big">4<span class="peak">Λ</span>4</p>
      <p class="lead" style="margin:18px auto 30px">This page isn't on the trail. The link is broken, or the page moved.</p>
      <a class="btn btn-primary" href="/">Back to base camp</a>
    </div>
  </section>
</Base>
