---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  /** Self-referencing canonical URL. Set on indexable pages only. */
  canonical?: string;
  /** Open Graph type; defaults to "website". */
  ogType?: string;
  /** OG/Twitter title; defaults to the page title. */
  ogTitle?: string;
  /** OG/Twitter description; defaults to the meta description. */
  ogDescription?: string;
  /** Home page uses in-page anchors (#services); inner pages link back to /#services. */
  home?: boolean;
  /** "Let's talk" button target. Contact page overrides to the in-page #form. */
  ctaHref?: string;
  /** Legal + 404 pages use the slim footer. */
  minimalFooter?: boolean;
}

const {
  title,
  description,
  noindex = false,
  canonical,
  ogType = 'website',
  ogTitle,
  ogDescription,
  home = false,
  ctaHref = '/contact',
  minimalFooter = false,
} = Astro.props;

const socialTitle = ogTitle ?? title;
const socialDesc = ogDescription ?? description;

// Anchor prefix: empty on the home page (same-page scroll), "/" elsewhere.
const a = home ? '' : '/';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
{description && <meta name="description" content={description} />}
{noindex && <meta name="robots" content="noindex" />}
{canonical && <link rel="canonical" href={canonical} />}
<link rel="icon" href="/favicon.ico" sizes="32x32">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<!-- Open Graph / Twitter — emitted on every page; pages pass their own values. -->
<meta property="og:site_name" content="Elevatek">
<meta property="og:type" content={ogType}>
<meta property="og:title" content={socialTitle}>
{socialDesc && <meta property="og:description" content={socialDesc} />}
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:locale" content="en_CA">
<meta property="og:image" content="https://elevatek.ca/og.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={socialTitle}>
{socialDesc && <meta name="twitter:description" content={socialDesc} />}
<slot name="head" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<slot name="head-end" />
</head>
<body>
<a class="skip" href="#main">Skip to content</a>

<header class="site-head">
  <div class="wrap">
    <a class="wordmark" href="/">ELEV<span class="peak">Λ</span>TEK</a>
    <button class="nav-toggle" aria-expanded="false" aria-controls="nav" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" id="nav">
      <a href={`${a}#services`}>What we do</a>
      <a href={`${a}#process`}>How we work</a>
      <a href={`${a}#pricing`}>Pricing</a>
      <a href={`${a}#clients`}>Proof</a>
      <a href={`${a}#faq`}>FAQ</a>
      {home && <Fragment set:html={`<!-- TODO: swap mailto for your Calendly / booking link -->`} />}
      <a class="btn btn-primary" href={ctaHref}>Let's talk</a>
    </nav>
  </div>
</header>

<main id="main">
  <slot />
</main>

{minimalFooter ? (
  <footer class="site-foot">
    <div class="wrap">
      <div class="foot-base" style="border-top:0;padding-top:0">
        <span>© <span id="year">2026</span> Elevatek Consulting Inc.</span>
        <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · <a href="/contact">Contact</a> · <button type="button" class="cookie-prefs" data-consent="reopen">Cookie preferences</button></span>
        <span>Built in Canada.</span>
      </div>
    </div>
  </footer>
) : (
  <footer class="site-foot" id="contact">
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <a class="wordmark" href="/">ELEV<span class="peak">Λ</span>TEK</a>
          <p class="foot-blurb">A Canadian GTM systems consultancy serving the Americas and Europe. Salesforce, HubSpot, Marketing Cloud.</p>
        </div>
        <div>
          <h4>Explore</h4>
          <ul>
            <li><a href={`${a}#services`}>What we do</a></li>
            <li><a href={`${a}#process`}>How we work</a></li>
            <li><a href={`${a}#pricing`}>Pricing</a></li>
            <li><a href={`${a}#faq`}>FAQ</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Contact</h4>
          <ul>
            <li><a href="mailto:info@elevatek.ca">info@elevatek.ca</a></li>
            <li><a href="tel:+15149618625">+1 (514) 961-8625</a></li>
          </ul>
        </div>
        <div>
          <h4>One RevOps tip a month</h4>
          {home && <Fragment set:html={`<!-- Newsletter form: wire \`action\` to your provider (the current site already has one running). -->`} />}
          <form class="news-form" name="newsletter" method="POST" action="/" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="newsletter">
            <p class="hp" aria-hidden="true"><label>Leave this empty<input name="bot-field" tabindex="-1" autocomplete="off"></label></p>
            <input type="email" name="email" placeholder="Email address" required aria-label="Email address">
            <button class="btn btn-primary" type="submit">Subscribe</button>
          </form>
          <p class="news-note">Something you can ship the same week. Unsubscribe anytime.</p>
        </div>
      </div>
      <div class="foot-base">
        <span>© <span id="year">2026</span> Elevatek Consulting Inc.</span>
        <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · <button type="button" class="cookie-prefs" data-consent="reopen">Cookie preferences</button></span>
        <span>Built in Canada.</span>
      </div>
    </div>
  </footer>
)}

<!-- Cookie consent — gates GA4 (Law 25: consent before non-essential cookies). -->
<aside class="consent" id="consent" role="dialog" aria-labelledby="consent-title" aria-describedby="consent-body" hidden>
  <div class="consent-card">
    <p class="consent-label">Cookies</p>
    <p class="consent-title" id="consent-title">Cookies on this site</p>
    <p class="consent-body" id="consent-body">We use analytics cookies to understand how the site is used — nothing more. You can accept, decline, or customise. See our <a href="/privacy">privacy policy</a>.</p>
    <div class="consent-actions">
      <button type="button" class="btn btn-primary" data-consent="accept">Accept</button>
      <button type="button" class="btn btn-light" data-consent="decline">Decline</button>
    </div>
    <div class="consent-customise">
      <button type="button" class="consent-more" data-consent="customise" aria-expanded="false" aria-controls="consent-panel">Customise</button>
    </div>
    <div class="consent-panel" id="consent-panel" hidden>
      <label class="consent-toggle">
        <span><b>Analytics</b><span class="consent-toggle-sub">Anonymous usage stats via Google Analytics. Off by default.</span></span>
        <input type="checkbox" id="consent-analytics">
      </label>
      <button type="button" class="btn btn-primary" data-consent="save">Save choices</button>
    </div>
  </div>
</aside>

<script is:inline src="/app.js"></script>
<script is:inline>
// Newsletter -> Netlify Forms. Static markup (data-netlify + form-name) is what
// Netlify detects at deploy; this posts url-encoded (incl. form-name + honeypot)
// to "/". Present only where the full footer renders; guarded for the others.
(() => {
  const nf = document.querySelector('.news-form');
  if (!nf) return;
  nf.addEventListener('submit', async e => {
    e.preventDefault();
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(nf)).toString()
      });
      if (!res.ok) throw new Error();
      nf.outerHTML = "<p class='news-note'>Thanks — you're on the list.</p>";
    } catch {
      let err = nf.parentElement.querySelector('.news-err');
      if (!err) { err = document.createElement('p'); err.className = 'news-note news-err'; err.style.color = '#B4400E'; nf.after(err); }
      err.textContent = "That didn't go through. Please try again.";
    }
  });
})();
</script>
<script is:inline>
// Cookie consent + GA4 gating (Google Consent Mode v2). GA4 is injected ONLY after
// the visitor accepts analytics — never on page load. Before consent and on decline
// there are zero GA cookies and zero googletagmanager/google-analytics requests.
(() => {
  const KEY = 'elevatek-consent';            // persistent choice: 'accepted' | 'declined'
  const DISMISS_KEY = 'elevatek-consent-dismissed'; // session-only dismiss (records no choice)
  const GA_ID = 'G-2J6WPHDXZQ';
  const banner = document.getElementById('consent');
  if (!banner) return;
  const panel = document.getElementById('consent-panel');
  const toggle = document.getElementById('consent-analytics');
  const moreBtn = banner.querySelector('[data-consent="customise"]');
  let gaLoaded = false;

  const read = () => { try { return localStorage.getItem(KEY); } catch (e) { return null; } };
  const save = (v) => { try { localStorage.setItem(KEY, v); } catch (e) {} };
  // Session-only dismiss (Esc / ask-me-later): sessionStorage, never the consent key.
  const dismissedThisSession = () => { try { return sessionStorage.getItem(DISMISS_KEY) === '1'; } catch (e) { return false; } };
  const markDismissed = () => { try { sessionStorage.setItem(DISMISS_KEY, '1'); } catch (e) {} };
  let lastTrigger = null; // element that opened the banner, for focus return

  function loadGA() {
    if (gaLoaded) return; gaLoaded = true;
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    window.gtag = gtag;
    // Consent Mode v2: all denied by default, only analytics granted on consent.
    gtag('consent', 'default', { ad_storage: 'denied', ad_user_data: 'denied', ad_personalization: 'denied', analytics_storage: 'denied' });
    gtag('consent', 'update', { analytics_storage: 'granted' });
    gtag('js', new Date());
    gtag('config', GA_ID);
    const s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);
  }

  function closePanel() { if (panel) panel.hidden = true; if (moreBtn) moreBtn.setAttribute('aria-expanded', 'false'); }
  function returnFocus() {
    // banner is about to hide; if focus sits inside it, move somewhere sane
    if (!banner.contains(document.activeElement)) return;
    if (lastTrigger && lastTrigger.isConnected) lastTrigger.focus();
    else if (document.activeElement && document.activeElement.blur) document.activeElement.blur();
  }
  function showBanner(trigger) { lastTrigger = trigger || null; banner.hidden = false; closePanel(); if (toggle) toggle.checked = (read() === 'accepted'); }
  function decide(choice) { save(choice); if (choice === 'accepted') loadGA(); returnFocus(); banner.hidden = true; closePanel(); }
  // Esc / ask-me-later: hide for this session only — record NO choice, write nothing
  // to the persistent consent key, and leave GA off (consent stays default-denied).
  function dismiss() { markDismissed(); returnFocus(); banner.hidden = true; closePanel(); }

  // First paint: honour a stored choice; a session-only dismiss suppresses the banner
  // for this session but records no consent, so it returns on the next visit.
  const saved = read();
  if (saved === 'accepted') loadGA();
  else if (saved === 'declined') { /* persisted refusal: stay off, no banner */ }
  else if (dismissedThisSession()) { /* dismissed this session: GA stays default-denied */ }
  else showBanner();

  document.addEventListener('click', (e) => {
    const el = e.target.closest('[data-consent]'); if (!el) return;
    const action = el.getAttribute('data-consent');
    if (action === 'accept') decide('accepted');
    else if (action === 'decline') decide('declined');
    else if (action === 'save') decide(toggle && toggle.checked ? 'accepted' : 'declined');
    else if (action === 'customise') {
      if (!panel) return;
      const opening = panel.hidden;
      panel.hidden = !opening;
      if (moreBtn) moreBtn.setAttribute('aria-expanded', String(opening));
      if (toggle) toggle.checked = (read() === 'accepted');
    } else if (action === 'reopen') {
      e.preventDefault();
      showBanner(el);
      const accept = banner.querySelector('[data-consent="accept"]');
      if (accept) accept.focus();
    }
  });

  // Esc dismisses the banner (privacy-protective; in addition to the visible
  // buttons, not a replacement). If the Customise panel is open, Esc steps back to
  // the banner first; otherwise it dismisses for this session only.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || banner.hidden) return;
    if (panel && !panel.hidden) {
      closePanel();
      if (moreBtn) moreBtn.focus();
    } else {
      dismiss();
    }
  });
})();
</script>
<slot name="body-end" />
</body>
</html>
